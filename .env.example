# Auth.js / Google OAuth
NEXTAUTH_SECRET=replace-with-long-random-secret
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
APP_BASE_URL=http://localhost:3000

# Cloudflare D1 REST API
CLOUDFLARE_ACCOUNT_ID=replace-with-cloudflare-account-id
CLOUDFLARE_D1_DATABASE_ID=replace-with-d1-database-id
CLOUDFLARE_API_TOKEN=replace-with-cloudflare-api-token

# ECPay
ECPAY_MERCHANT_ID=2000132
ECPAY_HASH_KEY=replace-with-ecpay-hash-key
ECPAY_HASH_IV=replace-with-ecpay-hash-iv
ECPAY_CASHIER_URL=https://payment-stage.ecpay.com.tw/Cashier/AioCheckOut/V5

# Gmail API
GMAIL_CLIENT_ID=replace-with-gmail-client-id
GMAIL_CLIENT_SECRET=replace-with-gmail-client-secret
GMAIL_REFRESH_TOKEN=replace-with-gmail-refresh-token
GMAIL_SENDER_EMAIL=sender@example.com

# Firebase (僅供 Google 登入與舊資料遷移腳本使用)
FIREBASE_PROJECT_ID=replace-with-firebase-project-id
FIREBASE_CLIENT_EMAIL=replace-with-firebase-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-private-key\n-----END PRIVATE KEY-----\n"
